{
  "name": "friends-devcontainer",
  "dockerComposeFile": [
    "../docker-compose.dev.yml"
  ],
  "service": "app",
  "workspaceFolder": "/workspace",
  "forwardPorts": [3000, 5173, 5432],
  "postCreateCommand": "cd apps/api && npm install && npx prisma generate && cd ../web && npm install",
  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash"
      }
    }
  }
}
