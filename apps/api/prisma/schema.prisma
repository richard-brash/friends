generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RequestStatus {
  REQUESTED
  PREPARING
  READY
  DELIVERED
  CANCELLED
  CLOSED_UNABLE
}

enum DeliveryOutcome {
  DELIVERED
  PERSON_NOT_FOUND
  DECLINED
  LOCATION_EMPTY
}

enum EncounterType {
  DELIVERY
  INTERACTION
}

enum NeedStatus {
  OPEN
  READY
  OUT_FOR_DELIVERY
  DELIVERED
  CLOSED_UNABLE
  UNAVAILABLE
  UNAVAILABLE_REVERSED
}

enum FulfillmentEventType {
  CREATED
  READY
  OUT_FOR_DELIVERY
  DELIVERED
  ATTEMPTED_NOT_FOUND
  CLOSED_UNABLE
  UNAVAILABLE
  UNAVAILABLE_REVERSED
}

enum InviteStatus {
  PENDING
  SENT
  ACCEPTED
  EXPIRED
  REVOKED
}

model Organization {
  id         String   @id @default(uuid()) @db.Uuid
  name       String
  created_at DateTime @default(now())

  users          User[]
  memberships    UserMembership[]
  invites        Invite[]
  people         Person[]
  locations      Location[]
  routes         Route[]
  quickPickItems QuickPickItem[]

  @@map("organizations")
}

model User {
  id              String   @id @default(uuid()) @db.Uuid
  organization_id String   @db.Uuid
  auth_user_id    String?  @unique
  phone_number    String?  @unique
  email           String?  @unique
  name            String
  created_at      DateTime @default(now())

  organization              Organization    @relation(fields: [organization_id], references: [id])
  userRoles                 UserRole[]
  memberships               UserMembership[]
  invites_sent              Invite[]        @relation("InvitedByUser")
  invites_accepted          Invite[]        @relation("AcceptedByUser")
  observedPersonLocations   PersonLocation[] @relation("PersonLocationObservedBy")
  takenRequests             Request[]        @relation("RequestTakenBy")
  fulfilledRequestItems     RequestItem[]    @relation("RequestItemFulfilledBy")
  deliveryAttempts          DeliveryAttempt[]
  observations              Observation[]

  @@index([organization_id])

  @@map("users")
}

model Role {
  id         String   @id @default(uuid()) @db.Uuid
  name       String   @unique
  created_at DateTime @default(now())

  userRoles UserRole[]

  @@map("roles")
}

model UserRole {
  id         String   @id @default(uuid()) @db.Uuid
  user_id    String   @db.Uuid
  role_id    String   @db.Uuid
  created_at DateTime @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)
  role Role @relation(fields: [role_id], references: [id], onDelete: Cascade)

  @@unique([user_id, role_id])
  @@index([user_id])
  @@index([role_id])
  @@map("user_roles")
}

model UserMembership {
  id              String   @id @default(uuid()) @db.Uuid
  user_id         String   @db.Uuid
  organization_id String   @db.Uuid
  status          String   @default("active")
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  user         User         @relation(fields: [user_id], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)

  @@unique([user_id, organization_id])
  @@index([user_id])
  @@index([organization_id])
  @@map("user_memberships")
}

model Invite {
  id              String   @id @default(uuid()) @db.Uuid
  organization_id String   @db.Uuid
  channel         String   @default("email")
  destination     String
  status          InviteStatus @default(PENDING)
  token_hash      String?  @unique
  invited_by_user_id String? @db.Uuid
  accepted_by_user_id String? @db.Uuid
  expires_at      DateTime?
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  organization    Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  invitedByUser   User?        @relation("InvitedByUser", fields: [invited_by_user_id], references: [id], onDelete: SetNull)
  acceptedByUser  User?        @relation("AcceptedByUser", fields: [accepted_by_user_id], references: [id], onDelete: SetNull)

  @@unique([organization_id, destination])
  @@index([organization_id])
  @@index([status])
  @@index([expires_at])
  @@map("invites")
}

model Person {
  id              String   @id @default(uuid()) @db.Uuid
  organization_id String   @db.Uuid
  display_name    String?
  normalized_name String?
  last_seen_at    DateTime?
  notes           String?
  created_at      DateTime @default(now())

  organization    Organization     @relation(fields: [organization_id], references: [id])
  aliases         PersonAlias[]
  locationHistory PersonLocation[]
  requests        Request[]
  encounters      Encounter[]
  observations    Observation[]

  @@index([organization_id])
  @@index([normalized_name])
  @@map("people")
}

model PersonAlias {
  id         String   @id @default(uuid()) @db.Uuid
  person_id  String   @db.Uuid
  alias      String
  created_at DateTime @default(now())

  person Person @relation(fields: [person_id], references: [id], onDelete: Cascade)

  @@index([person_id])
  @@unique([person_id, alias])
  @@map("person_aliases")
}

model Location {
  id              String   @id @default(uuid()) @db.Uuid
  organization_id String   @db.Uuid
  name            String
  description     String?
  is_active       Boolean  @default(true)
  latitude        Decimal? @db.Decimal(9, 6)
  longitude       Decimal? @db.Decimal(9, 6)
  created_at      DateTime @default(now())

  organization    Organization    @relation(fields: [organization_id], references: [id])
  personLocations PersonLocation[]
  routeLocations  RouteLocation[]
  requests        Request[]
  observations    Observation[]

  @@index([organization_id])
  @@map("locations")
}

model PersonLocation {
  id                  String   @id @default(uuid()) @db.Uuid
  person_id           String   @db.Uuid
  location_id         String   @db.Uuid
  observed_at         DateTime
  observed_by_user_id String?  @db.Uuid
  created_at          DateTime @default(now())

  person         Person @relation(fields: [person_id], references: [id], onDelete: Cascade)
  location       Location @relation(fields: [location_id], references: [id], onDelete: Cascade)
  observedByUser User?    @relation("PersonLocationObservedBy", fields: [observed_by_user_id], references: [id], onDelete: SetNull)

  @@index([person_id])
  @@index([location_id])
  @@index([observed_by_user_id])
  @@index([observed_at])
  @@map("person_locations")
}

model Route {
  id              String   @id @default(uuid()) @db.Uuid
  organization_id String   @db.Uuid
  name            String
  description     String?
  created_at      DateTime @default(now())

  organization Organization   @relation(fields: [organization_id], references: [id])
  stops        RouteLocation[]
  encounters   Encounter[]

  @@index([organization_id])
  @@map("routes")
}

model RouteLocation {
  id         String   @id @default(uuid()) @db.Uuid
  route_id   String   @db.Uuid
  location_id String  @db.Uuid
  stop_order Int
  created_at DateTime @default(now())

  route    Route    @relation(fields: [route_id], references: [id], onDelete: Cascade)
  location Location @relation(fields: [location_id], references: [id], onDelete: Cascade)

  @@index([route_id])
  @@index([location_id])
  @@unique([route_id, stop_order])
  @@unique([route_id, location_id])
  @@map("route_locations")
}

model Request {
  id               String   @id @default(uuid()) @db.Uuid
  person_id        String   @db.Uuid
  location_id      String   @db.Uuid
  taken_by_user_id String   @db.Uuid
  status           RequestStatus @default(REQUESTED)
  created_at       DateTime @default(now())
  notes            String?

  person      Person        @relation(fields: [person_id], references: [id], onDelete: Restrict)
  location    Location      @relation(fields: [location_id], references: [id], onDelete: Restrict)
  takenByUser User          @relation("RequestTakenBy", fields: [taken_by_user_id], references: [id], onDelete: Restrict)
  items       RequestItem[]
  encounters  Encounter[]

  @@index([person_id])
  @@index([location_id])
  @@index([status])
  @@index([location_id, status])
  @@index([taken_by_user_id])
  @@map("requests")
}

model RequestItem {
  id                    String   @id @default(uuid()) @db.Uuid
  request_id            String   @db.Uuid
  description           String
  quantity_requested    Int
  quantity_fulfilled    Int      @default(0)
  quantity_delivered    Int      @default(0)
  fulfilled_by_user_id  String?  @db.Uuid
  fulfilled_at          DateTime?
  status                NeedStatus @default(OPEN)
  created_at            DateTime @default(now())

  request            Request             @relation(fields: [request_id], references: [id], onDelete: Cascade)
  fulfilledByUser    User?               @relation("RequestItemFulfilledBy", fields: [fulfilled_by_user_id], references: [id], onDelete: SetNull)
  fulfillmentEvents  FulfillmentEvent[]
  deliveryAttempts DeliveryAttempt[]

  @@index([request_id])
  @@index([fulfilled_by_user_id])
  @@index([status])
  @@map("request_items")
}

model DeliveryAttempt {
  id              String          @id @default(uuid()) @db.Uuid
  request_item_id String          @db.Uuid
  user_id         String          @db.Uuid
  attempted_at    DateTime
  outcome         DeliveryOutcome
  notes           String?
  created_at      DateTime        @default(now())

  requestItem RequestItem @relation(fields: [request_item_id], references: [id], onDelete: Cascade)
  user        User        @relation(fields: [user_id], references: [id], onDelete: Restrict)

  @@index([request_item_id])
  @@index([user_id])
  @@index([attempted_at])
  @@map("delivery_attempts")
}

model Encounter {
  id            String        @id @default(uuid()) @db.Uuid
  person_id     String        @db.Uuid
  route_id      String?       @db.Uuid
  request_id    String?       @db.Uuid
  location_name String?
  type          EncounterType
  notes         String?
  metadata      Json?
  created_at    DateTime      @default(now())

  person  Person   @relation(fields: [person_id], references: [id], onDelete: Restrict)
  route   Route?   @relation(fields: [route_id], references: [id], onDelete: SetNull)
  request Request? @relation(fields: [request_id], references: [id], onDelete: SetNull)
  fulfillmentEvents FulfillmentEvent[]

  @@index([person_id, created_at])
  @@index([route_id, created_at])
  @@index([request_id])
  @@map("encounters")
}

model FulfillmentEvent {
  id          String               @id @default(uuid()) @db.Uuid
  need_id     String               @db.Uuid
  encounter_id String?             @db.Uuid
  event_type  FulfillmentEventType
  notes       String?
  created_at  DateTime             @default(now())

  need      RequestItem @relation(fields: [need_id], references: [id], onDelete: Cascade)
  encounter Encounter?  @relation(fields: [encounter_id], references: [id], onDelete: SetNull)

  @@index([need_id, created_at])
  @@index([encounter_id])
  @@map("fulfillment_events")
}

model QuickPickItem {
  id              String   @id @default(uuid()) @db.Uuid
  organization_id String   @db.Uuid
  label           String
  sort_order      Int      @default(0)
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  organization Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)

  @@unique([organization_id, label])
  @@index([organization_id, sort_order])
  @@map("quick_pick_items")
}

model Observation {
  id                  String   @id @default(uuid()) @db.Uuid
  person_id           String   @db.Uuid
  location_id         String   @db.Uuid
  observed_by_user_id String   @db.Uuid
  observed_at         DateTime
  notes               String
  created_at          DateTime @default(now())

  person         Person   @relation(fields: [person_id], references: [id], onDelete: Restrict)
  location       Location @relation(fields: [location_id], references: [id], onDelete: Restrict)
  observedByUser User     @relation(fields: [observed_by_user_id], references: [id], onDelete: Restrict)

  @@index([person_id])
  @@index([location_id])
  @@index([observed_by_user_id])
  @@index([observed_at])
  @@map("observations")
}
